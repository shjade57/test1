---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { readTime } from '../../utils/readTime';
import { getSlug } from '../../utils/slug';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = new Set<string>();
  posts.forEach(post => post.data.tags.forEach(tag => tags.add(tag)));
  return [...tags].map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allPosts = await getCollection('blog', ({ data }) =>
  !data.draft && data.tags.includes(tag!)
);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`#${tag}`}>
  <div class="container-narrow py-16 animate-fade-in">
    <a href="/tags" class="inline-flex items-center gap-1 text-sm text-[var(--c-text-muted)] hover:text-[var(--c-accent)] transition-colors mb-6">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
      所有标签
    </a>

    <h1 class="text-2xl font-bold tracking-tight text-[var(--c-text)] mb-1">
      {tag}
    </h1>
    <p class="text-[var(--c-text-muted)] mb-10">{sortedPosts.length} 篇文章</p>

    <div class="divide-y divide-[var(--c-border)]">
      {sortedPosts.length === 0 ? (
        <p class="text-[var(--c-text-muted)] py-16 text-center">暂无相关文章</p>
      ) : (
        sortedPosts.map((post, i) => (
          <div style={`animation-delay: ${i * 50}ms`} class="animate-fade-in">
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              slug={getSlug(post.id)}
              readMinutes={readTime(post.body || '')}
            />
          </div>
        ))
      )}
    </div>
  </div>
</BaseLayout>

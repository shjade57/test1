---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="搜索">
  <div class="container-narrow py-16 animate-fade-in">
    <h1 class="text-2xl font-bold tracking-tight text-[var(--c-text)] mb-1">搜索</h1>
    <p class="text-[var(--c-text-muted)] mb-10">输入关键词查找文章</p>

    <div id="search" class="w-full">
      <div class="relative">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-[var(--c-text-muted)] pointer-events-none" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          id="search-input"
          type="text"
          placeholder="搜索文章标题、内容..."
          class="w-full pl-12 pr-4 py-3.5 rounded-xl border-2 border-[var(--c-border)]
                 bg-[var(--c-bg)] text-[var(--c-text)] text-base
                 placeholder:text-[var(--c-text-muted)]
                 focus:border-[var(--c-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--c-accent-soft)]
                 transition-all duration-200"
        />
      </div>
      <div id="search-results" class="mt-8 space-y-4"></div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  async function initSearch() {
    try {
      const { PagefindUI } = await import('/pagefind/pagefind.js');
      new PagefindUI({
        element: '#search',
        showImages: false,
        excerptLength: 30,
        showSubResults: false,
        resetStyles: true,
      });
    } catch (e) {
      const results = document.getElementById('search-results');
      if (results) {
        results.innerHTML = '<p class="text-[var(--c-text-muted)] text-sm">搜索仅在构建后可用，请运行 <code class="text-[var(--c-accent)]">npm run build && npm run preview</code></p>';
      }
    }
  }
  initSearch();
</script>

<style is:inline>
  .pagefind-ui__result-title {
    font-weight: 600 !important;
    color: var(--c-text) !important;
  }
  .pagefind-ui__result-excerpt {
    color: var(--c-text-secondary) !important;
    font-size: 0.875rem !important;
  }
  .pagefind-ui__result-link {
    color: var(--c-accent) !important;
    font-size: 0.8rem !important;
  }
  .pagefind-ui__result {
    padding: 1rem 0 !important;
    border-bottom: 1px solid var(--c-border) !important;
  }
</style>

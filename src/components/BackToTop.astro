<button
  id="back-to-top"
  aria-label="回到顶部"
  class="fixed bottom-6 right-6 z-50 flex h-10 w-10 items-center justify-center
         rounded-full border border-[var(--c-border)] bg-[var(--c-bg-raised)]
         text-[var(--c-text-secondary)] shadow-sm opacity-0 translate-y-2
         pointer-events-none transition-all duration-200
         hover:border-[var(--c-accent)] hover:text-[var(--c-accent)] cursor-pointer"
>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 15l-6-6-6 6"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('back-to-top');
  if (btn) {
    window.addEventListener('scroll', () => {
      const show = window.scrollY > 400;
      btn.classList.toggle('opacity-0', !show);
      btn.classList.toggle('translate-y-2', !show);
      btn.classList.toggle('pointer-events-none', !show);
    }, { passive: true });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;

function navClass(path: string): string {
  const base = 'text-sm transition-colors pb-0.5 border-b-2 border-transparent';
  const match = path === '/'
    ? currentPath === '/'
    : currentPath.startsWith(path);
  return match
    ? `${base} text-[var(--c-text)] border-[var(--c-accent)]`
    : `${base} text-[var(--c-text-secondary)] hover:text-[var(--c-text)]`;
}
---

<header class="sticky top-0 z-50 bg-[var(--c-bg)]/80 backdrop-blur-md border-b border-[var(--c-border)]">
  <nav class="container-wide flex items-center justify-between h-14">
    <a href="/" class="text-base font-semibold tracking-tight text-[var(--c-text)] hover:text-[var(--c-accent)] transition-colors">
      ~/blog
    </a>

    <div class="flex items-center gap-1">
      <a href="/" class="px-3 py-1.5 rounded-md {navClass('/')}">首页</a>
      <a href="/tags" class="px-3 py-1.5 rounded-md {navClass('/tags')}">标签</a>
      <a href="/search" class="px-3 py-1.5 rounded-md {navClass('/search')}">搜索</a>
      <a href="/about" class="px-3 py-1.5 rounded-md {navClass('/about')}">关于</a>
      <div class="ml-2 pl-2 border-l border-[var(--c-border)]">
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>
